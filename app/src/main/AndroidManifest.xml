<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 摄像头权限 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-feature android:name="android.hardware.camera" />
    <uses-feature android:name="android.hardware.camera.autofocus" />

    <!-- OpenGL ES 要求 -->
    <uses-feature android:glEsVersion="${glEsVersion}" android:required="true" />

    <application
        android:name=".LaserCtrlMouseApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LaserCtrlMouse"
        android:requestLegacyExternalStorage="true"
        android:hardwareAccelerated="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.LaserCtrlMouse"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".ConnectActivity"
            android:exported="false"
            android:label="连接受控端"
            android:theme="@style/Theme.LaserCtrlMouse" />
            
        <activity
            android:name="com.scieford.laserctrlmouse.settings.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title"
            android:theme="@style/Theme.LaserCtrlMouse" />
            
        <!-- 系统设置界面 -->
        <activity
            android:name=".SystemActivity"
            android:exported="false"
            android:label="@string/system_settings"
            android:theme="@style/Theme.LaserCtrlMouse" />
            
        <!-- VIP购买界面 -->
        <activity
            android:name=".VipPurchaseActivity"
            android:exported="false"
            android:label="@string/upgrade_vip"
            android:theme="@style/Theme.LaserCtrlMouse" />
            
        <!-- 反馈界面 -->
        <activity
            android:name=".FeedbackActivity"
            android:exported="false"
            android:label="@string/feedback"
            android:theme="@style/Theme.LaserCtrlMouse" />
            
        <!-- WebView界面 -->
        <activity
            android:name=".WebViewActivity"
            android:exported="false"
            android:theme="@style/Theme.LaserCtrlMouse" />
    </application>

</manifest>