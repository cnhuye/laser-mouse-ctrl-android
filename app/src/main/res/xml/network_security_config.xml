<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 开发环境：允许所有明文通信 -->
    <debug-overrides>
        <!-- 在调试模式下允许明文通信 -->
        <trust-anchors>
            <certificates src="user"/>
            <certificates src="system"/>
        </trust-anchors>
    </debug-overrides>
    
    <!-- 生产环境的基础配置 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config> 